generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  spot       String
  date       String
  waveHeight String
  duration   String
  board      String?
  rating     Int      @default(0)
  notes      String?
  createdAt  DateTime @default(now())

  @@index([userId])
}